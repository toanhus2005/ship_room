{
    "video":  {
                  "source":  "data/sample1.mp4",
                  "timezone":  "Asia/Ho_Chi_Minh"
              },
    "stream":  {
                   "sample_fps":  5.0,
                   "output_frames_dir":  "artifacts/frames",
                   "save_sampled_frames":  false
               },
    "detection":  {
                      "model_name":  "yolov8s.pt",
                      "confidence_threshold":  0.4,
                      "iou_threshold":  0.5,
                      "min_box_area_ratio":  0.002,
                      "border_exclusion_px":  3,
                      "inference_scale":  0.75,
                      "inference_imgsz":  640,
                      "inference_half":  false
                  },
    "tracking":  {
                     "track_buffer":  30,
                     "match_threshold":  0.7,
                     "id_reassign_iou_threshold":  0.12,
                     "id_reassign_center_distance":  0.75,
                     "id_reassign_max_frame_gap":  24,
                     "id_reassign_min_area_ratio":  0.45,
                     "id_reassign_max_area_ratio":  2.4,
                     "id_reassign_max_aspect_ratio_delta":  0.7
                 },
    "zone":  {
                 "package_zone_polygon":  [
                                              [
                                                  200,
                                                  150
                                              ],
                                              [
                                                  1100,
                                                  150
                                              ],
                                              [
                                                  1100,
                                                  650
                                              ],
                                              [
                                                  200,
                                                  650
                                              ]
                                          ]
             },
    "output":  {
                   "events_jsonl":  "artifacts/events/person_tracks.jsonl"
               }
}
