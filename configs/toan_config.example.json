{
  "video": {
    "source": "data/ship_room_sample.mp4",
    "timezone": "Asia/Ho_Chi_Minh"
  },
  "stream": {
    "sample_fps": 5.0,
    "output_frames_dir": "artifacts/frames",
    "save_sampled_frames": false,
    "skip_until_person": true
  },
  "detection": {
    "model_name": "yolov8n.pt",
    "confidence_threshold": 0.8,
    "repo_device": "0"
  },
  "tracking": {
    "track_buffer": 70,
    "deepsort_n_init": 3,
    "deepsort_max_iou_distance": 0.7,
    "deepsort_max_cosine_distance": 0.2,
    "deepsort_nn_budget": 100,
    "repo_deepsort_weights": "deep_sort/deep/checkpoint/ckpt.t7",
    "repo_deepsort_use_cuda": true,
    "repo_deepsort_min_confidence": 0.3
  },
  "zone": {
    "package_zone_polygon": [[200, 150], [1100, 150], [1100, 650], [200, 650]]
  },
  "output": {
    "events_jsonl": "artifacts/events/person_tracks.jsonl"
  }
}
