{
  "video": {
    "source": "data/ship_room_sample.mp4",
    "timezone": "Asia/Ho_Chi_Minh"
  },
  "stream": {
    "sample_fps": 5.0,
    "output_frames_dir": "artifacts/frames",
    "save_sampled_frames": false
  },
  "detection": {
    "model_name": "yolov8s.pt",
    "confidence_threshold": 0.45,
    "iou_threshold": 0.5,
    "min_box_area_ratio": 0.003,
    "min_box_height_ratio": 0.12,
    "min_box_height_width_ratio": 1.15,
    "border_exclusion_px": 3,
    "inference_scale": 0.85,
    "inference_imgsz": 640,
    "inference_half": false,
    "max_detections": 25
  },
  "tracking": {
    "track_buffer": 80,
    "match_threshold": 0.7,
    "deepsort_n_init": 3,
    "deepsort_max_iou_distance": 0.7,
    "deepsort_max_cosine_distance": 0.25,
    "deepsort_nn_budget": 100,
    "deepsort_embedder": "mobilenet"
  },
  "zone": {
    "package_zone_polygon": [[200, 150], [1100, 150], [1100, 650], [200, 650]]
  },
  "output": {
    "events_jsonl": "artifacts/events/person_tracks.jsonl"
  }
}
