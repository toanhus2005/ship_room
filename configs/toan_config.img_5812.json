{
    "video": {
        "source": "data/IMG_5812.MOV",
        "timezone": "Asia/Ho_Chi_Minh"
    },
    "stream": {
        "sample_fps": 10.0,
        "output_frames_dir": "artifacts/frames",
        "save_sampled_frames": false
    },
    "detection": {
        "model_name": "yolov8m.pt",
        "confidence_threshold": 0.4,
        "repo_device": "0"
    },
    "tracking": {
        "track_buffer": 200,
        "deepsort_n_init": 3,
        "deepsort_max_iou_distance": 0.7,
        "deepsort_max_cosine_distance": 0.45,
        "deepsort_nn_budget": 100,
        "repo_deepsort_weights": "deep_sort/deep/checkpoint/ckpt.t7",
        "repo_deepsort_use_cuda": true,
        "repo_deepsort_min_confidence": 0.3
    },
    "zone": {
        "package_zone_polygon": [[1060, 520], [1480, 520], [1480, 860], [1060, 860]]
    },
    "output": {
        "events_jsonl": "artifacts/events/person_tracks.jsonl"
    }
}